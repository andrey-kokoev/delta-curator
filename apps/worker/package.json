{
  "name": "@delta-curator/worker",
  "version": "0.1.0",
  "description": "Cloudflare Worker app for Delta-Curator",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "prebuild": "rm -rf public && mkdir -p public && cp -r ../ui/dist/* public/",
    "build": "tsc",
    "predeploy": "pnpm run prebuild",
    "deploy": "wrangler deploy",
    "preview": "pnpm run prebuild && wrangler dev",
    "test": "vitest run"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "@delta-curator/plugin-ranker-workers-ai": "workspace:*",
    "@delta-curator/protocol": "workspace:*",
    "@delta-curator/runtime": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260228.0",
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.67.0"
  }
}
