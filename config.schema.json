{
  "$id": "https://delta-curator.local/schemas/config.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Delta-Curator Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["topic", "sources", "pipeline", "storage"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "topic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "company_match", "product_families"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable identifier for this topic instance.",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "description": "Human-readable label.",
          "minLength": 1
        },
        "company_match": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "needle"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["substring_i", "regex_i"],
              "description": "How to match company mentions."
            },
            "needle": {
              "type": "string",
              "description": "Substring or regex pattern.",
              "minLength": 1
            }
          }
        },
        "product_families": {
          "type": "array",
          "description": "List of product family ids used by the extractor and shown in digests.",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "uniqueItems": true
        }
      }
    },

    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    },

    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["normalizer", "extractor", "resolver", "comparator", "rankers", "decider", "merger"],
      "properties": {
        "normalizer": { "$ref": "#/$defs/pluginRef" },
        "extractor": { "$ref": "#/$defs/pluginRef" },
        "resolver": { "$ref": "#/$defs/pluginRef" },
        "comparator": { "$ref": "#/$defs/pluginRef" },

        "rankers": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ingest", "search"],
          "properties": {
            "ingest": { "$ref": "#/$defs/ingestRanker" },
            "search": { "$ref": "#/$defs/searchRanker" }
          }
        },

        "decider": { "$ref": "#/$defs/pluginRef" },
        "merger": { "$ref": "#/$defs/pluginRef" }
      }
    },

    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["committer", "artifacts"],
      "properties": {
        "committer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["plugin", "config"],
          "properties": {
            "plugin": { "type": "string", "enum": ["d1_committer"], "default": "d1_committer" },
            "config": { "$ref": "#/$defs/d1CommitterConfig" }
          }
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "bucket"],
          "properties": {
            "kind": { "type": "string", "enum": ["r2"], "default": "r2" },
            "bucket": {
              "type": "string",
              "description": "R2 bucket binding name in Worker env (e.g. ARTIFACTS).",
              "minLength": 1
            },
            "prefix": {
              "type": "string",
              "description": "Optional prefix for all artifact keys.",
              "default": "delta-curator/"
            }
          }
        }
      }
    },

    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_items_per_batch": { "type": "integer", "minimum": 1, "maximum": 5000, "default": 50 },
        "clock": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {
            "mode": { "type": "string", "enum": ["system", "fixed"], "default": "system" },
            "fixed_iso": {
              "type": "string",
              "description": "Used only in tests when mode=fixed.",
              "format": "date-time"
            }
          },
          "allOf": [
            {
              "if": { "properties": { "mode": { "const": "fixed" } }, "required": ["mode"] },
              "then": { "required": ["fixed_iso"] }
            }
          ]
        }
      },
      "default": {}
    },

    "schedules": {
      "type": "object",
      "additionalProperties": false,
      "description": "Worker scheduled run configuration. Cron is expressed in UTC in wrangler.toml; this is logical intent only.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_id", "max_items"],
            "properties": {
              "source_id": { "type": "string", "minLength": 1 },
              "max_items": { "type": "integer", "minimum": 1, "maximum": 5000, "default": 50 }
            }
          }
        }
      },
      "default": { "enabled": false, "sources": [] }
    }
  },

  "$defs": {
    "jsonValue": {
      "description": "Any JSON value.",
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        { "type": "array", "items": { "$ref": "#/$defs/jsonValue" } },
        { "type": "object", "additionalProperties": { "$ref": "#/$defs/jsonValue" } }
      ]
    },

    "pluginRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plugin"],
      "properties": {
        "plugin": {
          "type": "string",
          "description": "Plugin id (registered in runtime/plugin loader).",
          "minLength": 1
        },
        "config": {
          "$ref": "#/$defs/jsonValue",
          "description": "Plugin-specific configuration."
        }
      }
    },

    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "plugin", "config"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "plugin": { "type": "string", "minLength": 1 },
        "config": { "$ref": "#/$defs/jsonValue" },
        "state": {
          "$ref": "#/$defs/jsonValue",
          "description": "Optional initial cursor state. Persisted state lives in committer source_state table."
        }
      }
    },

    "ingestRanker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "backend"],
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "backend": {
          "type": "string",
          "enum": ["none", "workers_ai_rerank"],
          "default": "none"
        },
        "model": {
          "type": "string",
          "description": "Workers AI model id (only for workers_ai_rerank).",
          "default": "@cf/baai/bge-reranker-base"
        },
        "query": {
          "type": "string",
          "description": "Query string used for reranking at ingest time.",
          "minLength": 1
        },
        "max_passage_chars": {
          "type": "integer",
          "minimum": 256,
          "maximum": 12000,
          "default": 4000
        }
      },
      "allOf": [
        {
          "if": { "properties": { "backend": { "const": "workers_ai_rerank" } }, "required": ["backend"] },
          "then": { "required": ["query"] }
        }
      ]
    },

    "searchRanker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "backend"],
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "backend": {
          "type": "string",
          "enum": ["none", "ai_search_rerank"],
          "default": "none"
        },
        "index": {
          "type": "string",
          "description": "AI Search index name.",
          "minLength": 1
        },
        "rerank": { "type": "boolean", "default": true }
      },
      "allOf": [
        {
          "if": { "properties": { "backend": { "const": "ai_search_rerank" } }, "required": ["backend"] },
          "then": { "required": ["index"] }
        }
      ]
    },

    "d1CommitterConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["database"],
      "properties": {
        "database": {
          "type": "string",
          "description": "D1 database binding name in Worker env (e.g. DB).",
          "minLength": 1
        },
        "migrations_dir": {
          "type": "string",
          "description": "Relative path to SQL migrations (used by tooling/tests).",
          "default": "packages/runtime/src/commit/migrations"
        }
      }
    }
  }
}