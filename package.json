{
  "name": "delta-curator",
  "version": "0.1.0",
  "description": "Event-sourced novelty accumulation system",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "dev": "delta-curator watch"
  },
  "workspaces": [
    "packages/*",
    "plugins/*",
    "apps/*",
    "examples/*"
  ],
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
