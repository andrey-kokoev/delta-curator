{
  "name": "delta-curator",
  "version": "0.1.0",
  "description": "Event-sourced novelty accumulation system",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "build:ui": "pnpm -F @delta-curator/ui run build",
    "dev": "pnpm -F @delta-curator/ui run dev",
    "dev:worker": "pnpm -F @delta-curator/worker exec wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "deploy": "pnpm run build && pnpm -F @delta-curator/worker exec wrangler deploy"
  },
  "workspaces": [
    "packages/*",
    "plugins/*/*",
    "apps/*",
    "examples/*"
  ],
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "wrangler": "^4.67.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
